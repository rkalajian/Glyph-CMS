{
    "kind": "collectionType",
    "collectionName": "forms",
    "info": {
        "singularName": "form",
        "pluralName": "forms",
        "displayName": "Form",
        "description": "Form builder for contact forms and surveys. Use the embed code to add forms to any page or post."
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "name": {
            "type": "string",
            "required": true
        },
        "slug": {
            "type": "uid",
            "targetField": "name",
            "required": true
        },
        "description": {
            "type": "text"
        },
        "fields": {
            "type": "json",
            "required": true,
            "default": []
        },
        "submitButtonLabel": {
            "type": "string",
            "default": "Submit"
        },
        "successType": {
            "type": "enumeration",
            "enum": ["message", "redirect"],
            "default": "message"
        },
        "successMessage": {
            "type": "text",
            "default": "Thank you! Your submission has been received.",
            "conditions": {
                "visible": { "==": [{ "var": "successType" }, "message"] }
            }
        },
        "successRedirectUrl": {
            "type": "string",
            "conditions": {
                "visible": { "==": [{ "var": "successType" }, "redirect"] }
            }
        },
        "notifyEmail": {
            "type": "string"
        },
        "notifySubmitter": {
            "type": "boolean",
            "default": false
        },
        "emailSubject": {
            "type": "string"
        },
        "submissions": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::form-submission.form-submission",
            "mappedBy": "form",
            "description": "Submissions for this form"
        }
    }
}
