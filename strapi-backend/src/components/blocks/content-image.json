{
  "collectionName": "components_blocks_content_images",
  "info": {
    "displayName": "Content + Image",
    "description": "H2 + body + optional CTA button paired with image"
  },
  "attributes": {
    "heading": {
      "type": "string"
    },
    "body": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "buttonText": {
      "type": "string"
    },
    "buttonUrl": {
      "type": "string"
    },
    "secondaryButtonText": {
      "type": "string"
    },
    "secondaryButtonUrl": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "imagePosition": {
      "type": "enumeration",
      "enum": [
        "left",
        "right"
      ],
      "default": "right"
    },
    "imageObjectFit": {
      "type": "enumeration",
      "enum": [
        "cover",
        "contain"
      ],
      "default": "cover"
    },
    "anchorId": {
      "type": "string"
    }
  }
}
