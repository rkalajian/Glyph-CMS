{
  "collectionName": "components_blocks_membership_pricings",
  "info": {
    "displayName": "Membership Pricing",
    "description": "Grid of membership tier pricing cards with heading and description"
  },
  "attributes": {
    "heading": {
      "type": "string"
    },
    "description": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "tiers": {
      "type": "component",
      "repeatable": true,
      "component": "shared.pricing-tier"
    },
    "footerContent": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "anchorId": {
      "type": "string"
    }
  }
}
