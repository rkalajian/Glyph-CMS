{
  "kind": "singleType",
  "collectionName": "theme_options",
  "info": {
    "singularName": "theme-option",
    "pluralName": "theme-options",
    "displayName": "Theme Options",
    "description": "Site-wide theme settings: logo, GTM, Marker.io, breadcrumbs, and social links"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "siteName": {
      "type": "string"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "favicon": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "frontendMode": {
      "type": "enumeration",
      "enum": ["react", "static"],
      "default": "react",
      "displayName": "Frontend mode",
      "description": "React = SPA (client-side). Static = pre-rendered HTML at build time."
    },
    "showBreadcrumbs": {
      "type": "boolean",
      "default": true
    },
    "blogPostsPerPage": {
      "type": "integer",
      "default": 12,
      "min": 1,
      "max": 100,
      "displayName": "Blog posts per page"
    },
    "pressReleasesPerPage": {
      "type": "integer",
      "default": 12,
      "min": 1,
      "max": 100,
      "displayName": "Press releases per page"
    },
    "social": {
      "type": "component",
      "repeatable": false,
      "component": "theme-option.social",
      "displayName": "Social"
    },
    "mailgun": {
      "type": "component",
      "repeatable": false,
      "component": "theme-option.mailgun",
      "displayName": "Mailgun"
    },
    "gtm": {
      "type": "component",
      "repeatable": false,
      "component": "theme-option.gtm",
      "displayName": "GTM"
    },
    "marker": {
      "type": "component",
      "repeatable": false,
      "component": "theme-option.marker",
      "displayName": "Marker"
    },
    "googleCalendarId": {
      "type": "string",
      "description": "Google Calendar ID (e.g. abc123@group.calendar.google.com)"
    },
    "googleCalendarApiKey": {
      "type": "string",
      "description": "Google Calendar API key (keep secret — not exposed publicly)"
    },
    "googleCalendarSyncEnabled": {
      "type": "boolean",
      "default": true,
      "description": "Enable automatic Google Calendar sync"
    },
    "searchConfig": {
      "type": "component",
      "repeatable": true,
      "component": "shared.search-content-type",
      "displayName": "Search Configuration"
    },
    "recaptchaSiteKey": {
      "type": "string",
      "description": "Google reCAPTCHA v2 site key (public — safe to expose)"
    },
    "recaptchaSecretKey": {
      "type": "string",
      "private": true,
      "description": "Google reCAPTCHA v2 secret key (private — never sent to browser)"
    }
  }
}
