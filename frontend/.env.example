# Strapi API URL. Required for production deploy.
# In dev, omit — Next.js proxies /api → localhost:1337.
NEXT_PUBLIC_STRAPI_URL=https://your-strapi.onrender.com

# Public domain (no protocol) — used for sitemap.xml, canonical URLs, JSON-LD.
# NEXT_PUBLIC_SITE_DOMAIN=www.example.com

# Set to "true" on staging to emit a disallow-all robots.txt and empty sitemap.
# NEXT_PUBLIC_NOINDEX=true

# IANA timezone used to render event dates identically on server and client.
# Default: America/New_York
# NEXT_PUBLIC_TIMEZONE=America/New_York
